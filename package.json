{
  "name": "scenario-globe-handover-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "npm run build && node scripts/verify-phase0.mjs && npm run test:contract",
    "test:contract": "npx tsx tests/contract/verify-tile-feature-infobox-sanitization.ts && npx tsx tests/contract/verify-handover-selection-passthrough.ts",
    "test:phase1": "npm run build && npm run test:contract && node tests/smoke/bootstrap-loads-assets-and-workers.mjs && node tests/smoke/local-focus-interactions.mjs",
    "test:local-focus": "npm run build && node tests/smoke/local-focus-interactions.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "cesium": "1.140.0"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-static-copy": "^4.0.1"
  }
}
